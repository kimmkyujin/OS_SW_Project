<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beige_background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="문의 내역 확인"
                android:textColor="#000000"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_marginBottom="30dp" />

            <TextView
                android:id="@+id/tv_user_detail_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="카테고리: "
                android:textColor="#666666"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_user_detail_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_edittext_rounded"
                android:padding="15dp"
                android:text="제목"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tv_user_detail_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="150dp"
                android:background="@drawable/bg_edittext_rounded"
                android:padding="15dp"
                android:text="문의 내용"
                android:textColor="#333333"
                android:textSize="16sp"
                android:layout_marginBottom="30dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="관리자 답변"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tv_admin_answer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="150dp"
                android:background="@drawable/bg_edittext_rounded"
                android:padding="15dp"
                android:text="답변 대기 중입니다."
                android:textColor="@color/orange_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="30dp" />

            <Button
                android:id="@+id/btn_back_to_list"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:backgroundTint="@color/orange_primary"
                android:text="목록으로 돌아가기"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#FFF5EE"
        app:itemIconTint="@color/orange_primary"
        app:itemTextColor="@color/orange_primary"
        app:menu="@menu/bottom_nav_menu"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
